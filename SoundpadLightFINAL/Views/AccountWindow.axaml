<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="260"
        x:Class="SoundpadLightFINAL.Views.AccountWindow"
        Background="{StaticResource BrushAccentBlack}"
        Width="600"
        Height="260"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        CanResize="False"
        Title=""
        Icon="avares://SoundpadLightFINAL/Images/SoundpadLightIcon.png">

  <Border CornerRadius="10"
          BorderThickness="1"
          BorderBrush="{StaticResource BrushPrimaryRedDark}"
          Background="{StaticResource BrushAccentDarkGray}"
          Padding="16">

    <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="*">
      <!-- Заголовок -->
      <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
        <Image Source="avares://SoundpadLightFINAL/Images/SoundpadLightIcon.png"
               Width="28" Height="28" Margin="0,0,8,0"/>
        <StackPanel>
          <TextBlock x:Name="AccountNameTextBlock"
                     FontSize="18"
                     FontWeight="Bold"/>
          <TextBlock Text="Account overview"
                     Foreground="{StaticResource BrushAccentLightGray}"
                     FontSize="12"/>
        </StackPanel>
      </StackPanel>

       <!-- Статистика -->
       <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,*" ColumnDefinitions="*">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
          <TextBlock Text="Total playlists:"
                     Width="200"
                     Foreground="{StaticResource BrushAccentLightGray}"/>
          <TextBlock x:Name="PlaylistsCountTextBlock"
                     FontWeight="Bold"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
          <TextBlock Text="Total sounds:"
                     Width="200"
                     Foreground="{StaticResource BrushAccentLightGray}"/>
          <TextBlock x:Name="SoundsCountTextBlock"
                     FontWeight="Bold"/>
        </StackPanel>

         <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,6">
          <TextBlock Text="Sounds per playlist (avg):"
                     Width="200"
                     Foreground="{StaticResource BrushAccentLightGray}"/>
          <TextBlock x:Name="AveragePerPlaylistTextBlock"
                     FontWeight="Bold"/>
        </StackPanel>

         <TextBlock Grid.Row="3"
                    x:Name="ErrorTextBlock"
                    Foreground="{StaticResource BrushErrorRed}"
                    Margin="0,8,0,0"
                    TextWrapping="Wrap"/>
      </Grid>

       <!-- Нижняя панель -->
       <StackPanel Grid.Row="2"
                   Orientation="Horizontal"
                   HorizontalAlignment="Right"
                   Margin="0,16,0,0"
                   Spacing="8">
         <Button x:Name="RenameUserButton" Content="Rename account" Width="130"/>
         <Button x:Name="LogoutButton" Content="Log out" Width="90"/>
         <Button x:Name="CloseButton" Content="Close" Width="80"/>
       </StackPanel>
    </Grid>
  </Border>
</Window>


