<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SoundpadLightFINAL.App"
             RequestedThemeVariant="Dark">

  <Application.Resources>
    <!-- Основная цветовая схема -->
    <Color x:Key="PrimaryRed">#FF3030</Color>
    <Color x:Key="PrimaryRedDark">#CC2020</Color>
    <Color x:Key="AccentBlack">#FF121212</Color>
    <Color x:Key="AccentDarkGray">#FF1E1E1E</Color>
    <Color x:Key="AccentLightGray">#FFB0B0B0</Color>

    <SolidColorBrush x:Key="BrushPrimaryRed" Color="{StaticResource PrimaryRed}" />
    <SolidColorBrush x:Key="BrushPrimaryRedDark" Color="{StaticResource PrimaryRedDark}" />
    <SolidColorBrush x:Key="BrushAccentBlack" Color="{StaticResource AccentBlack}" />
    <SolidColorBrush x:Key="BrushAccentDarkGray" Color="{StaticResource AccentDarkGray}" />
    <SolidColorBrush x:Key="BrushAccentLightGray" Color="{StaticResource AccentLightGray}" />
    <SolidColorBrush x:Key="BrushErrorRed" Color="#FFE53935" />
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>

    <!-- Общий стиль для кнопок (красно-черная тема) -->
    <Style Selector="Button">
      <Setter Property="Background" Value="{StaticResource BrushPrimaryRed}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource BrushPrimaryRedDark}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="6,3" />
    </Style>

    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="{StaticResource BrushPrimaryRedDark}" />
    </Style>

    <Style Selector="Button:pressed">
      <Setter Property="Background" Value="{StaticResource BrushAccentBlack}" />
    </Style>

    <!-- Текстовые поля в темном стиле -->
    <Style Selector="TextBox">
      <Setter Property="Background" Value="{StaticResource BrushAccentDarkGray}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource BrushPrimaryRed}" />
      <Setter Property="CornerRadius" Value="3" />
    </Style>

    <!-- Лейблы/заголовки -->
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="White" />
    </Style>

  </Application.Styles>
</Application>